rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 헬퍼 함수
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // users 컬렉션
    match /users/{userId} {
      // 읽기: 인증된 사용자는 자신의 정보와 다른 사용자 정보 읽기 가능
      allow read: if isAuthenticated();
      
      // 생성: 자신의 문서만 생성 가능 (userId가 자신의 uid와 일치)
      allow create: if isAuthenticated() && 
        request.auth.uid == userId &&
        request.resource.data.uid == userId;
      
      // 수정/삭제: 관리자만 가능
      allow update, delete: if isAdmin();
    }
    
    // applications 컬렉션
    match /applications/{applicationId} {
      // 읽기: 인증된 사용자 (목록은 클라이언트에서 본인 필터링)
      allow read: if isAuthenticated();
      
      // 생성: 인증된 사용자가 자신의 신청서만 생성 가능
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      
      // 수정/삭제: 관리자 또는 해당 신청서 소유자(본인)만 가능
      allow update, delete: if isAdmin() ||
        (isAuthenticated() && request.auth.uid == resource.data.userId);
    }
    
    // settings 컬렉션
    match /settings/{document=**} {
      // 읽기: 모든 사용자 가능 (공개)
      allow read: if true;
      
      // 쓰기: 관리자만 가능
      allow write: if isAdmin();
    }
  }
}
